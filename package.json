{
  "name": "transcription-app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "backend": "bun --watch backend/bin/server.ts",
    "client": "cd client && bun run dev",
    "dev": "concurrently \"bun run backend\" \"bun run client\"",
    "server": "bun backend/index.js",
    "bench:transcription": "bun scripts/benchmark-transcriptions.js",
    "build": "bun build --compile --bytecode --minify --sourcemap backend/bin/server.ts --outfile dist/server",
    "start": "dist/server",
    "build:go": "cd go-backend && go build -o server ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3",
    "hono": "^4.12.14",
    "multer": "^2.1.1",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "bun-types": "^1.3.14",
    "concurrently": "^9.1.2"
  }
}
