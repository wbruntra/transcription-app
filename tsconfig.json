{
  "compilerOptions": {
    // This is where you define your aliases.
    "paths": {
      // The key is the alias you want to use in your imports.
      // The value is an array of paths where the resolver should look.
      "~backend/*": ["./backend/*"],
      "~client/*": ["./client/*"],
      // Add any other aliases you need
    }
  }
}
